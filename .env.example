# === Claude (Anthropic) ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_ORCHESTRATOR_MODEL=claude-opus-4-1-20250805
CLAUDE_SMALL_MODEL=claude-haiku-4-5-20251001

# === Azure OpenAI: chat (optional fallback LLM) ===
AZURE_API_KEY=xxxxxxxx
AZURE_API_VERSION=2024-12-01-preview
AZURE_DEPLOYMENT=gpt-4o
AZURE_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_MODEL=gpt-4o

# === Azure OpenAI: text embeddings (brand RAG) ===
EMBED_API_KEY=xxxxxxxx
EMBED_API_VERSION=2024-12-01-preview
EMBED_DEPLOYMENT=text-embedding-3-large
EMBED_ENDPOINT=https://<your-resource>.openai.azure.com/openai/deployments/text-embedding-3-large/embeddings?api-version=2023-05-15
EMBED_MODEL=text-embedding-3-large
EMBED_DIMENSIONS=3072

# === Google Gemini (image editing for after-mockup) ===
GEMINI_API_KEY=xxxxxxxx
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# === Cloudflare Workers AI (fallback image gen) ===
CLOUDFLARE_ACCOUNT_ID=xxxxxxxx
CLOUDFLARE_API_TOKEN=xxxxxxxx
CLOUDFLARE_IMAGE_MODEL=@cf/stabilityai/stable-diffusion-xl-base-1.0

# === Database ===
DATABASE_URL=postgresql+psycopg://avms:avms@localhost:5432/avms

# === Auth / JWT ===
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=1440

# === Storage ===
STORAGE_DIR=backend/storage

# === App ===
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
